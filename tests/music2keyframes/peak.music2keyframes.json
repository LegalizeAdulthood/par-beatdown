{
  "schema": "par-beatdown.music2keyframes",
  "version": 1,
  "source": {
    "timeline": "song.music.json",
    "fps": 30.0,
    "offset_seconds": 0.0
  },
  "output": {
    "mode": "overlay",
    "namespace": "music"
  },
  "bindings": [
    {
      "source": "music.peak",
      "target": "shake.amount",
      "op": "add",
      "scale": 0.5,
      "offset": 0.0,
      "clamp": {
        "min": 0.0,
        "max": 1.0
      }
    }
  ]
}
