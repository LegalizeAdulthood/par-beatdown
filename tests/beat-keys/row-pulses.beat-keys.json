{
  "schema": "par-beatdown.beat-keys",
  "version": 1,
  "source": {
    "timeline": "song.music.json",
    "fps": 10.0,
    "offset_seconds": 0.0
  },
  "output": {
    "mode": "overlay",
    "namespace": "music"
  },
  "bindings": [
    {
      "source": "music.row_pulse",
      "target": "row.flash",
      "op": "replace",
      "scale": 1.0,
      "offset": 0.25,
      "decay_seconds": 0.1,
      "clamp": {
        "min": 0.0,
        "max": 1.0
      }
    }
  ]
}
