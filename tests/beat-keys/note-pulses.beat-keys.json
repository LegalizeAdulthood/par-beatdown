{
  "schema": "par-beatdown.beat-keys",
  "version": 1,
  "source": {
    "timeline": "song.music.json",
    "fps": 10.0,
    "offset_seconds": 0.0
  },
  "output": {
    "mode": "overlay",
    "namespace": "music"
  },
  "bindings": [
    {
      "source": "music.note_pulse",
      "target": "note.energy",
      "op": "add",
      "scale": 0.5,
      "offset": 0.0,
      "decay_seconds": 0.2
    },
    {
      "source": "music.effect_pulse",
      "target": "effect.flash",
      "op": "replace",
      "scale": 1.0,
      "offset": 0.0,
      "decay_seconds": 0.1
    }
  ]
}
